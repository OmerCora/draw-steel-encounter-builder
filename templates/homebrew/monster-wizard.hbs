{{!-- Monster Builder – two-panel layout: inputs (left) + stat block preview (right) --}}
<div class="dshomebrew-wizard">

  <div class="dshomebrew-wizard-body">

    {{!-- ══════════ LEFT PANEL: Input Fields ══════════ --}}
    <div class="dshomebrew-input-panel">

      {{!-- Basics section --}}
      <section class="dshomebrew-section">
        <h3 class="dshomebrew-section-title">{{localize "DSENCOUNTER.Homebrew.Section.Basics"}}</h3>

        <div class="dshomebrew-field">
          <label>{{localize "DSENCOUNTER.Homebrew.Field.Name"}}</label>
          <input type="text" data-field="name" value="{{data.name}}" placeholder="{{localize "DSENCOUNTER.Homebrew.Placeholder.Name"}}">
        </div>

        <div class="dshomebrew-field-row dshomebrew-field-row-4">
          <div class="dshomebrew-field dshomebrew-field-sm">
            <label>{{localize "DSENCOUNTER.Homebrew.Field.Level"}}</label>
            <select data-field="level">
              {{#each levelOptions}}
              <option value="{{value}}" {{#if selected}}selected{{/if}}>{{value}}</option>
              {{/each}}
            </select>
          </div>
          <div class="dshomebrew-field">
            <label>{{localize "DSENCOUNTER.Homebrew.Field.Role"}}</label>
            <select data-field="roleKey">
              {{#each roleOptions}}
              <option value="{{key}}" {{#if selected}}selected{{/if}}>{{label}}</option>
              {{/each}}
            </select>
          </div>
          <div class="dshomebrew-field">
            <label>{{localize "DSENCOUNTER.Homebrew.Field.Organization"}}</label>
            <select data-field="orgKey">
              {{#each orgOptions}}
              <option value="{{key}}" {{#if selected}}selected{{/if}}>{{label}}</option>
              {{/each}}
            </select>
          </div>
        </div>

        <div class="dshomebrew-field-row dshomebrew-field-row-4">
          <div class="dshomebrew-field">
            <label>{{localize "DSENCOUNTER.Homebrew.Field.Size"}}</label>
            <select data-field="sizeCombo">
              {{#each sizeOptions}}
              <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
              {{/each}}
            </select>
          </div>
          <div class="dshomebrew-field dshomebrew-field-sm">
            <label>{{localize "DSENCOUNTER.Homebrew.Field.Speed"}}</label>
            <input type="number" data-field="speed" value="{{data.speed}}" min="0">
          </div>
          <div class="dshomebrew-field dshomebrew-field-sm">
            <label>{{localize "DSENCOUNTER.Homebrew.Field.Stability"}}</label>
            <input type="number" data-field="stability" value="{{data.stability}}" min="0">
          </div>
        </div>

        <div class="dshomebrew-field dshomebrew-extra-stamina">
          <label>
            <input type="checkbox" data-field="extraStamina" {{#if data.extraStamina}}checked{{/if}}>
            {{localize "DSENCOUNTER.Homebrew.Field.ExtraStamina"}}
          </label>
        </div>
      </section>

      {{!-- Keywords & Movement --}}
      <section class="dshomebrew-section">
        <h3 class="dshomebrew-section-title">{{localize "DSENCOUNTER.Homebrew.Section.Traits"}}</h3>

        <div class="dshomebrew-field">
          <label>{{localize "DSENCOUNTER.Homebrew.Field.Keywords"}}</label>
          <div class="dshomebrew-tag-select" data-field="keywords">
            {{#each keywordOptions}}
            <label class="dshomebrew-tag {{#if selected}}selected{{/if}}">
              <input type="checkbox" value="{{key}}" {{#if selected}}checked{{/if}}>
              <span>{{label}}</span>
            </label>
            {{/each}}
          </div>
        </div>

        <div class="dshomebrew-field">
          <label>{{localize "DSENCOUNTER.Homebrew.Field.MovementTypes"}}</label>
          <div class="dshomebrew-tag-select" data-field="movementTypes">
            {{#each movementTypeOptions}}
            <label class="dshomebrew-tag {{#if selected}}selected{{/if}}">
              <input type="checkbox" value="{{key}}" {{#if selected}}checked{{/if}}>
              <span>{{label}}</span>
            </label>
            {{/each}}
          </div>
        </div>
      </section>

      {{!-- Immunities & Weaknesses --}}
      <section class="dshomebrew-section">
        <h3 class="dshomebrew-section-title">{{localize "DSENCOUNTER.Homebrew.Section.Defenses"}}</h3>

        <div class="dshomebrew-field">
          <label>{{localize "DSENCOUNTER.Homebrew.Field.Immunities"}}</label>
          <div class="dshomebrew-dmg-list" data-list="immunities">
            {{#each data.immunities}}
            <div class="dshomebrew-dmg-entry" data-index="{{@index}}">
              <select data-field="immunities-type" data-index="{{@index}}">
                {{#each ../damageTypeOptionsAll}}
                <option value="{{key}}" {{#if (eq key ../type)}}selected{{/if}}>{{label}}</option>
                {{/each}}
              </select>
              <input type="number" data-field="immunities-value" data-index="{{@index}}" value="{{value}}" min="0" class="dshomebrew-dmg-value">
              <button type="button" class="dshomebrew-btn-icon" data-action="removeImmunity" data-index="{{@index}}" title="Remove">
                <i class="fa-solid fa-xmark"></i>
              </button>
            </div>
            {{/each}}
            <button type="button" class="dshomebrew-btn-small" data-action="addImmunity">
              <i class="fa-solid fa-plus"></i> {{localize "DSENCOUNTER.Homebrew.AddImmunity"}}
            </button>
          </div>
        </div>

        <div class="dshomebrew-field">
          <label>{{localize "DSENCOUNTER.Homebrew.Field.Weaknesses"}}</label>
          <div class="dshomebrew-dmg-list" data-list="weaknesses">
            {{#each data.weaknesses}}
            <div class="dshomebrew-dmg-entry" data-index="{{@index}}">
              <select data-field="weaknesses-type" data-index="{{@index}}">
                {{#each ../damageTypeOptionsAll}}
                <option value="{{key}}" {{#if (eq key ../type)}}selected{{/if}}>{{label}}</option>
                {{/each}}
              </select>
              <input type="number" data-field="weaknesses-value" data-index="{{@index}}" value="{{value}}" min="0" class="dshomebrew-dmg-value">
              <button type="button" class="dshomebrew-btn-icon" data-action="removeWeakness" data-index="{{@index}}" title="Remove">
                <i class="fa-solid fa-xmark"></i>
              </button>
            </div>
            {{/each}}
            <button type="button" class="dshomebrew-btn-small" data-action="addWeakness">
              <i class="fa-solid fa-plus"></i> {{localize "DSENCOUNTER.Homebrew.AddWeakness"}}
            </button>
          </div>
        </div>
      </section>

      {{!-- Characteristics --}}
      <section class="dshomebrew-section">
        <h3 class="dshomebrew-section-title">{{localize "DSENCOUNTER.Homebrew.Section.Characteristics"}}</h3>

        <div class="dshomebrew-char-grid">
          {{#each chars}}
          <div class="dshomebrew-char-field">
            <label>{{label}}</label>
            <input type="number" data-field="characteristics" data-index="{{@index}}" value="{{value}}">
          </div>
          {{/each}}
        </div>

        <div class="dshomebrew-suggested">
          <span class="dshomebrew-hint">
            {{localize "DSENCOUNTER.Homebrew.Hint.Suggested"}}
            {{#each suggestedChars}}{{#unless @first}}, {{/unless}}{{this}}{{/each}}
          </span>
          <button type="button" class="dshomebrew-btn-small" data-action="applySuggested">
            <i class="fa-solid fa-wand-magic-sparkles"></i> {{localize "DSENCOUNTER.Homebrew.ApplySuggested"}}
          </button>
        </div>

      </section>

      {{!-- Abilities --}}
      <section class="dshomebrew-section">
        <h3 class="dshomebrew-section-title">{{localize "DSENCOUNTER.Homebrew.Section.Abilities"}}</h3>

        <div class="dshomebrew-ability-actions">
          <button type="button" class="dshomebrew-btn-ability" data-action="addSignatureAbility" {{#if hasSignature}}disabled title="{{localize "DSENCOUNTER.Homebrew.Hint.OneSignature"}}"{{/if}}>
            <i class="fa-solid fa-star"></i> {{localize "DSENCOUNTER.Homebrew.AddSignature"}}
          </button>
          <button type="button" class="dshomebrew-btn-ability" disabled title="{{localize "DSENCOUNTER.Homebrew.ComingSoon"}}">
            <i class="fa-solid fa-bolt"></i> {{localize "DSENCOUNTER.Homebrew.AddAbility"}}
          </button>
          <button type="button" class="dshomebrew-btn-ability" disabled title="{{localize "DSENCOUNTER.Homebrew.ComingSoon"}}">
            <i class="fa-solid fa-scroll"></i> {{localize "DSENCOUNTER.Homebrew.AddTrait"}}
          </button>
          <button type="button" class="dshomebrew-btn-ability" disabled title="{{localize "DSENCOUNTER.Homebrew.ComingSoon"}}">
            <i class="fa-solid fa-skull"></i> {{localize "DSENCOUNTER.Homebrew.AddMalice"}}
          </button>
        </div>

        {{!-- Signature ability inline editor (shown after clicking Add Signature) --}}
        {{#if showSignatureEditor}}
        <div class="dshomebrew-sig-editor">
          <div class="dshomebrew-sig-header">
            <h4><i class="fa-solid fa-star"></i> {{localize "DSENCOUNTER.Homebrew.AddSignature"}}</h4>
            <button type="button" class="dshomebrew-btn-icon" data-action="removeSignatureAbility" title="Remove">
              <i class="fa-solid fa-trash"></i>
            </button>
          </div>

          <div class="dshomebrew-field">
            <label>{{localize "DSENCOUNTER.Homebrew.Field.AbilityName"}}</label>
            <input type="text" data-field="abilityName" value="{{data.abilityName}}" placeholder="{{localize "DSENCOUNTER.Homebrew.Placeholder.AbilityName"}}">
          </div>

          <div class="dshomebrew-field-row">
            <div class="dshomebrew-field">
              <label>{{localize "DSENCOUNTER.Homebrew.Field.DistanceType"}}</label>
              <select data-field="distanceType">
                {{#each distanceOptions}}
                <option value="{{key}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                {{/each}}
              </select>
            </div>
            {{#each distanceFields}}
            <div class="dshomebrew-field dshomebrew-field-sm">
              <label>{{label}}</label>
              <input type="number" data-field="{{dataKey}}" value="{{value}}" min="1">
            </div>
            {{/each}}
          </div>

          <div class="dshomebrew-field-row">
            <div class="dshomebrew-field">
              <label>{{localize "DSENCOUNTER.Homebrew.Field.TargetType"}}</label>
              <select data-field="targetType">
                {{#each targetTypeOptions}}
                <option value="{{key}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                {{/each}}
              </select>
            </div>
            {{#if targetHasValue}}
            <div class="dshomebrew-field dshomebrew-field-sm">
              <label>{{localize "DSENCOUNTER.Homebrew.Field.TargetValue"}}</label>
              <input type="number" data-field="targetValue" value="{{data.targetValue}}" min="1">
            </div>
            {{/if}}
            <div class="dshomebrew-field">
              <label>{{localize "DSENCOUNTER.Homebrew.Field.TargetCustom"}}</label>
              <input type="text" data-field="targetCustom" value="{{data.targetCustom}}" placeholder="{{localize "DSENCOUNTER.Homebrew.Placeholder.TargetCustom"}}">
            </div>
          </div>

          <div class="dshomebrew-field">
            <label>{{localize "DSENCOUNTER.Homebrew.Field.PowerRollChars"}}</label>
            <div class="dshomebrew-tag-select" data-field="powerRollChars">
              {{#each charSelectOptions}}
              <label class="dshomebrew-tag {{#if selected}}selected{{/if}}">
                <input type="checkbox" value="{{key}}" {{#if selected}}checked{{/if}}>
                <span>{{label}}</span>
              </label>
              {{/each}}
            </div>
          </div>

          {{!-- Power Roll Effects --}}
          <div class="dshomebrew-effects-section">
            <label class="dshomebrew-effects-label">Power Roll Effects</label>
            {{#each effects}}
            <div class="dshomebrew-effect-card" data-effect-index="{{@index}}">
              <div class="dshomebrew-effect-header">
                <select data-effect-id="{{id}}" data-effect-field="type">
                  {{#each typeOptions}}
                  <option value="{{key}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                  {{/each}}
                </select>
                <input type="text" data-effect-id="{{id}}" data-effect-field="name" value="{{name}}" placeholder="{{localize "DSENCOUNTER.Homebrew.Placeholder.EffectName"}}">
                <button type="button" class="dshomebrew-btn-icon" data-action="removeEffect" data-effect-id="{{id}}" title="Remove">
                  <i class="fa-solid fa-xmark"></i>
                </button>
              </div>

              {{!-- Damage fields --}}
              {{#if isDamage}}
              <div class="dshomebrew-effect-body">
                <div class="dshomebrew-effect-tiers">
                  <div class="dshomebrew-effect-tier">
                    <span class="dshomebrew-tier-label">≤11</span>
                    <input type="text" data-effect-id="{{id}}" data-effect-field="tier1Value" value="{{tier1Value}}" placeholder="{{tier1Placeholder}}">
                  </div>
                  <div class="dshomebrew-effect-tier">
                    <span class="dshomebrew-tier-label">12–16</span>
                    <input type="text" data-effect-id="{{id}}" data-effect-field="tier2Value" value="{{tier2Value}}" placeholder="{{tier2Placeholder}}">
                  </div>
                  <div class="dshomebrew-effect-tier">
                    <span class="dshomebrew-tier-label">17+</span>
                    <input type="text" data-effect-id="{{id}}" data-effect-field="tier3Value" value="{{tier3Value}}" placeholder="{{tier3Placeholder}}">
                  </div>
                </div>
                <div class="dshomebrew-tag-select" data-field="damageTypes" data-effect-id="{{id}}">
                  {{#each damageTypeOptions}}
                  <label class="dshomebrew-tag {{#if selected}}selected{{/if}}">
                    <input type="checkbox" value="{{key}}" {{#if selected}}checked{{/if}}>
                    <span>{{label}}</span>
                  </label>
                  {{/each}}
                </div>
              </div>
              {{/if}}

              {{!-- Applied fields (per-tier) --}}
              {{#if isApplied}}
              <div class="dshomebrew-effect-body">
                <div class="dshomebrew-effect-tiers dshomebrew-effect-tiers-text">
                  <div class="dshomebrew-effect-tier dshomebrew-tier-applied">
                    <span class="dshomebrew-tier-label">≤11</span>
                    <select data-effect-id="{{id}}" data-effect-field="tier1Condition">
                      {{#each tier1ConditionOptions}}
                      <option value="{{key}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                      {{/each}}
                    </select>
                    <select data-effect-id="{{id}}" data-effect-field="tier1ConditionEnd">
                      {{#each tier1ConditionEndOptions}}
                      <option value="{{key}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                      {{/each}}
                    </select>
                  </div>
                  <div class="dshomebrew-effect-tier dshomebrew-tier-applied">
                    <span class="dshomebrew-tier-label">12–16</span>
                    <select data-effect-id="{{id}}" data-effect-field="tier2Condition">
                      {{#each tier2ConditionOptions}}
                      <option value="{{key}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                      {{/each}}
                    </select>
                    <select data-effect-id="{{id}}" data-effect-field="tier2ConditionEnd">
                      {{#each tier2ConditionEndOptions}}
                      <option value="{{key}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                      {{/each}}
                    </select>
                  </div>
                  <div class="dshomebrew-effect-tier dshomebrew-tier-applied">
                    <span class="dshomebrew-tier-label">17+</span>
                    <select data-effect-id="{{id}}" data-effect-field="tier3Condition">
                      {{#each tier3ConditionOptions}}
                      <option value="{{key}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                      {{/each}}
                    </select>
                    <select data-effect-id="{{id}}" data-effect-field="tier3ConditionEnd">
                      {{#each tier3ConditionEndOptions}}
                      <option value="{{key}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                      {{/each}}
                    </select>
                  </div>
                </div>
              </div>
              {{/if}}

              {{!-- Forced movement fields (per-tier) --}}
              {{#if isForced}}
              <div class="dshomebrew-effect-body">
                <div class="dshomebrew-effect-tiers dshomebrew-effect-tiers-text">
                  <div class="dshomebrew-effect-tier dshomebrew-tier-forced">
                    <span class="dshomebrew-tier-label">≤11</span>
                    <select data-effect-id="{{id}}" data-effect-field="tier1Movement">
                      {{#each tier1MovementOptions}}
                      <option value="{{key}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                      {{/each}}
                    </select>
                    <input type="number" data-effect-id="{{id}}" data-effect-field="tier1Distance" value="{{tier1Distance}}" min="0">
                  </div>
                  <div class="dshomebrew-effect-tier dshomebrew-tier-forced">
                    <span class="dshomebrew-tier-label">12–16</span>
                    <select data-effect-id="{{id}}" data-effect-field="tier2Movement">
                      {{#each tier2MovementOptions}}
                      <option value="{{key}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                      {{/each}}
                    </select>
                    <input type="number" data-effect-id="{{id}}" data-effect-field="tier2Distance" value="{{tier2Distance}}" min="0">
                  </div>
                  <div class="dshomebrew-effect-tier dshomebrew-tier-forced">
                    <span class="dshomebrew-tier-label">17+</span>
                    <select data-effect-id="{{id}}" data-effect-field="tier3Movement">
                      {{#each tier3MovementOptions}}
                      <option value="{{key}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                      {{/each}}
                    </select>
                    <input type="number" data-effect-id="{{id}}" data-effect-field="tier3Distance" value="{{tier3Distance}}" min="0">
                  </div>
                </div>
              </div>
              {{/if}}

              {{!-- Other fields --}}
              {{#if isOther}}
              <div class="dshomebrew-effect-body">
                <div class="dshomebrew-effect-tiers dshomebrew-effect-tiers-text">
                  <div class="dshomebrew-effect-tier">
                    <span class="dshomebrew-tier-label">≤11</span>
                    <input type="text" data-effect-id="{{id}}" data-effect-field="tier1Display" value="{{tier1Display}}" placeholder="{{localize "DSENCOUNTER.Homebrew.Placeholder.TierDisplay"}}">
                  </div>
                  <div class="dshomebrew-effect-tier">
                    <span class="dshomebrew-tier-label">12–16</span>
                    <input type="text" data-effect-id="{{id}}" data-effect-field="tier2Display" value="{{tier2Display}}" placeholder="{{localize "DSENCOUNTER.Homebrew.Placeholder.TierDisplay"}}">
                  </div>
                  <div class="dshomebrew-effect-tier">
                    <span class="dshomebrew-tier-label">17+</span>
                    <input type="text" data-effect-id="{{id}}" data-effect-field="tier3Display" value="{{tier3Display}}" placeholder="{{localize "DSENCOUNTER.Homebrew.Placeholder.TierDisplay"}}">
                  </div>
                </div>
              </div>
              {{/if}}

              {{!-- Resource fields --}}
              {{#if isResource}}
              <div class="dshomebrew-effect-body">
                <div class="dshomebrew-field-row">
                  <div class="dshomebrew-field">
                    <label>{{localize "DSENCOUNTER.Homebrew.Field.ResourceType"}}</label>
                    <select data-effect-id="{{id}}" data-effect-field="resourceType">
                      {{#each resourceTypeOptions}}
                      <option value="{{key}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                      {{/each}}
                    </select>
                  </div>
                </div>
                <div class="dshomebrew-effect-tiers">
                  <div class="dshomebrew-effect-tier">
                    <span class="dshomebrew-tier-label">≤11</span>
                    <input type="number" data-effect-id="{{id}}" data-effect-field="tier1Amount" value="{{tier1Amount}}" min="0">
                  </div>
                  <div class="dshomebrew-effect-tier">
                    <span class="dshomebrew-tier-label">12–16</span>
                    <input type="number" data-effect-id="{{id}}" data-effect-field="tier2Amount" value="{{tier2Amount}}" min="0">
                  </div>
                  <div class="dshomebrew-effect-tier">
                    <span class="dshomebrew-tier-label">17+</span>
                    <input type="number" data-effect-id="{{id}}" data-effect-field="tier3Amount" value="{{tier3Amount}}" min="0">
                  </div>
                </div>
              </div>
              {{/if}}
            </div>
            {{/each}}

            <button type="button" class="dshomebrew-btn-small" data-action="addEffect">
              <i class="fa-solid fa-plus"></i> {{localize "DSENCOUNTER.Homebrew.AddEffect"}}
            </button>
          </div>
        </div>
        {{/if}}
      </section>

    </div>{{!-- .dshomebrew-input-panel --}}

    {{!-- ══════════ RIGHT PANEL: Stat Block Preview ══════════ --}}
    <div class="dshomebrew-preview-panel">
      <div class="dshomebrew-statblock">

        {{!-- Header --}}
        <div class="dshomebrew-sb-header">
          <div class="dshomebrew-sb-name">{{#if data.name}}{{data.name}}{{else}}<span class="dshomebrew-sb-placeholder">{{localize "DSENCOUNTER.Homebrew.Placeholder.Name"}}</span>{{/if}}</div>
          <div class="dshomebrew-sb-subtitle">
            {{localize "DSENCOUNTER.Homebrew.Preview.Level"}} {{data.level}} {{roleLabel}} ({{orgLabel}})
          </div>
        </div>

        {{!-- Keywords / Type line --}}
        {{#if keywordLabels.length}}
        <div class="dshomebrew-sb-line dshomebrew-sb-keywords">
          <span class="dshomebrew-sb-label">{{localize "DSENCOUNTER.Homebrew.Preview.Keywords"}}:</span> {{keywordLabels}}
        </div>
        {{/if}}

        <div class="dshomebrew-sb-divider"></div>

        {{!-- EV --}}
        <div class="dshomebrew-sb-line">
          <span class="dshomebrew-sb-label">EV:</span>
          {{#if isMinion}}{{stats.ev}} ({{localize "DSENCOUNTER.Homebrew.Preview.EVFor4"}}){{else}}{{stats.ev}}{{/if}}
        </div>

        {{!-- Stamina --}}
        <div class="dshomebrew-sb-line">
          <span class="dshomebrew-sb-label">{{localize "DSENCOUNTER.Homebrew.Stat.Stamina"}}:</span> {{stats.stamina}}
        </div>

        {{!-- Speed / Movement --}}
        <div class="dshomebrew-sb-line">
          <span class="dshomebrew-sb-label">{{localize "DSENCOUNTER.Homebrew.Field.Speed"}}:</span> {{data.speed}}{{#if movementLabel}} ({{movementLabel}}){{/if}}
        </div>

        {{!-- Size --}}
        <div class="dshomebrew-sb-line">
          <span class="dshomebrew-sb-label">{{localize "DSENCOUNTER.Homebrew.Field.Size"}}:</span> {{sizeDisplay}}
        </div>

        {{!-- Stability --}}
        {{#if data.stability}}
        <div class="dshomebrew-sb-line">
          <span class="dshomebrew-sb-label">{{localize "DSENCOUNTER.Homebrew.Field.Stability"}}:</span> {{data.stability}}
        </div>
        {{/if}}

        {{!-- Free Strike --}}
        <div class="dshomebrew-sb-line">
          <span class="dshomebrew-sb-label">{{localize "DSENCOUNTER.Homebrew.Stat.FreeStrike"}}:</span> {{stats.freeStrike}}
        </div>

        {{!-- Immunities --}}
        {{#if immunityDisplay}}
        <div class="dshomebrew-sb-line">
          <span class="dshomebrew-sb-label">{{localize "DSENCOUNTER.Homebrew.Field.Immunities"}}:</span> {{immunityDisplay}}
        </div>
        {{/if}}

        {{!-- Weaknesses --}}
        {{#if weaknessDisplay}}
        <div class="dshomebrew-sb-line">
          <span class="dshomebrew-sb-label">{{localize "DSENCOUNTER.Homebrew.Field.Weaknesses"}}:</span> {{weaknessDisplay}}
        </div>
        {{/if}}

        <div class="dshomebrew-sb-divider"></div>

        {{!-- Characteristics --}}
        <div class="dshomebrew-sb-chars">
          {{#each chars}}
          <div class="dshomebrew-sb-char">
            <span class="dshomebrew-sb-char-label">{{abbrev}}</span>
            <span class="dshomebrew-sb-char-value">{{#if (gt value 0)}}+{{/if}}{{value}}</span>
          </div>
          {{/each}}
        </div>

        <div class="dshomebrew-sb-divider"></div>

        {{!-- Signature Ability --}}
        {{#if showSignatureEditor}}
        <div class="dshomebrew-sb-ability">
          <div class="dshomebrew-sb-ability-header">
            <span class="dshomebrew-sb-ability-name">
              <i class="fa-solid fa-star"></i>
              {{#if data.abilityName}}{{data.abilityName}}{{else}}{{localize "DSENCOUNTER.Homebrew.Placeholder.AbilityName"}}{{/if}}
            </span>
            <span class="dshomebrew-sb-ability-cost">◆</span>
          </div>
          <div class="dshomebrew-sb-ability-meta">
            {{#if sigAbilityKeywordLabels}}Keywords: {{sigAbilityKeywordLabels}}<br>{{/if}}
            Distance: {{sigDistanceLabel}} ◆ Target: {{sigTargetLabel}}
          </div>
          <div class="dshomebrew-sb-ability-roll">
            Power Roll + {{sigCharLabel}}
          </div>
          {{#if hasEffects}}
          <div class="dshomebrew-sb-tiers">
            <div class="dshomebrew-sb-tier">
              <span class="dshomebrew-sb-tier-label">≤11:</span>
              <span>{{sigTierPreview.[1]}}</span>
            </div>
            <div class="dshomebrew-sb-tier">
              <span class="dshomebrew-sb-tier-label">12–16:</span>
              <span>{{sigTierPreview.[2]}}</span>
            </div>
            <div class="dshomebrew-sb-tier">
              <span class="dshomebrew-sb-tier-label">17+:</span>
              <span>{{sigTierPreview.[3]}}</span>
            </div>
          </div>
          {{/if}}
        </div>
        {{/if}}

      </div>{{!-- .dshomebrew-statblock --}}
    </div>{{!-- .dshomebrew-preview-panel --}}

  </div>{{!-- .dshomebrew-wizard-body --}}

  {{!-- Footer --}}
  <footer class="dshomebrew-wizard-footer">
    <div class="dshomebrew-spacer"></div>
    <button type="button" class="dshomebrew-btn-create" data-action="createMonster">
      <i class="fa-solid fa-plus"></i> {{localize "DSENCOUNTER.Homebrew.CreateMonster"}}
    </button>
  </footer>

</div>
