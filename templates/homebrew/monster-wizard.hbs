{{!-- Monster Builder – two-panel layout: inputs (left) + stat block preview (right) --}}
<div class="dshomebrew-wizard">

  <div class="dshomebrew-wizard-body">

    {{!-- ══════════ LEFT PANEL: Input Fields ══════════ --}}
    <div class="dshomebrew-input-panel">

      {{!-- Basics section --}}
      <section class="dshomebrew-section">
        <h3 class="dshomebrew-section-title">{{localize "DSENCOUNTER.Homebrew.Section.Basics"}}</h3>

        <div class="dshomebrew-field">
          <label>{{localize "DSENCOUNTER.Homebrew.Field.Name"}}</label>
          <input type="text" data-field="name" value="{{data.name}}" placeholder="{{localize "DSENCOUNTER.Homebrew.Placeholder.Name"}}">
        </div>

        <div class="dshomebrew-field-row dshomebrew-field-row-4">
          <div class="dshomebrew-field dshomebrew-field-sm">
            <label>{{localize "DSENCOUNTER.Homebrew.Field.Level"}}</label>
            <select data-field="level">
              {{#each levelOptions}}
              <option value="{{value}}" {{#if selected}}selected{{/if}}>{{value}}</option>
              {{/each}}
            </select>
          </div>
          <div class="dshomebrew-field">
            <label>{{localize "DSENCOUNTER.Homebrew.Field.Role"}}</label>
            <select data-field="roleKey">
              {{#each roleOptions}}
              <option value="{{key}}" {{#if selected}}selected{{/if}}>{{label}}</option>
              {{/each}}
            </select>
          </div>
          <div class="dshomebrew-field">
            <label>{{localize "DSENCOUNTER.Homebrew.Field.Organization"}}</label>
            <select data-field="orgKey">
              {{#each orgOptions}}
              <option value="{{key}}" {{#if selected}}selected{{/if}}>{{label}}</option>
              {{/each}}
            </select>
          </div>
        </div>

        <div class="dshomebrew-field-row dshomebrew-field-row-4">
          <div class="dshomebrew-field">
            <label>{{localize "DSENCOUNTER.Homebrew.Field.Size"}}</label>
            <select data-field="sizeCombo">
              {{#each sizeOptions}}
              <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
              {{/each}}
            </select>
          </div>
          <div class="dshomebrew-field dshomebrew-field-sm">
            <label>{{localize "DSENCOUNTER.Homebrew.Field.Speed"}}</label>
            <input type="number" data-field="speed" value="{{data.speed}}" min="0">
          </div>
          <div class="dshomebrew-field dshomebrew-field-sm">
            <label>{{localize "DSENCOUNTER.Homebrew.Field.Stability"}}</label>
            <input type="number" data-field="stability" value="{{data.stability}}" min="0">
          </div>
        </div>

        <div class="dshomebrew-field dshomebrew-extra-stamina">
          <label>
            <input type="checkbox" data-field="extraStamina" {{#if data.extraStamina}}checked{{/if}}>
            {{localize "DSENCOUNTER.Homebrew.Field.ExtraStamina"}}
          </label>
        </div>
      </section>

      {{!-- Keywords & Movement --}}
      <section class="dshomebrew-section">
        <h3 class="dshomebrew-section-title">{{localize "DSENCOUNTER.Homebrew.Section.Traits"}}</h3>

        <div class="dshomebrew-field">
          <label>{{localize "DSENCOUNTER.Homebrew.Field.Keywords"}}</label>
          <div class="dshomebrew-tag-select" data-field="keywords">
            {{#each keywordOptions}}
            <label class="dshomebrew-tag {{#if selected}}selected{{/if}}">
              <input type="checkbox" value="{{key}}" {{#if selected}}checked{{/if}}>
              <span>{{label}}</span>
            </label>
            {{/each}}
          </div>
        </div>

        <div class="dshomebrew-field">
          <label>{{localize "DSENCOUNTER.Homebrew.Field.MovementTypes"}}</label>
          <div class="dshomebrew-tag-select" data-field="movementTypes">
            {{#each movementTypeOptions}}
            <label class="dshomebrew-tag {{#if selected}}selected{{/if}}">
              <input type="checkbox" value="{{key}}" {{#if selected}}checked{{/if}}>
              <span>{{label}}</span>
            </label>
            {{/each}}
          </div>
        </div>
      </section>

      {{!-- Immunities & Weaknesses --}}
      <section class="dshomebrew-section">
        <h3 class="dshomebrew-section-title">{{localize "DSENCOUNTER.Homebrew.Section.Defenses"}}</h3>

        <div class="dshomebrew-field">
          <label>{{localize "DSENCOUNTER.Homebrew.Field.Immunities"}}</label>
          <div class="dshomebrew-dmg-list" data-list="immunities">
            {{#each data.immunities}}
            <div class="dshomebrew-dmg-entry" data-index="{{@index}}">
              <select data-field="immunities-type" data-index="{{@index}}">
                {{#each ../damageTypeOptionsAll}}
                <option value="{{key}}" {{#if (eq key ../type)}}selected{{/if}}>{{label}}</option>
                {{/each}}
              </select>
              <input type="number" data-field="immunities-value" data-index="{{@index}}" value="{{value}}" min="0" class="dshomebrew-dmg-value">
              <button type="button" class="dshomebrew-btn-icon" data-action="removeImmunity" data-index="{{@index}}" title="Remove">
                <i class="fa-solid fa-xmark"></i>
              </button>
            </div>
            {{/each}}
            <button type="button" class="dshomebrew-btn-small" data-action="addImmunity">
              <i class="fa-solid fa-plus"></i> {{localize "DSENCOUNTER.Homebrew.AddImmunity"}}
            </button>
          </div>
        </div>

        <div class="dshomebrew-field">
          <label>{{localize "DSENCOUNTER.Homebrew.Field.Weaknesses"}}</label>
          <div class="dshomebrew-dmg-list" data-list="weaknesses">
            {{#each data.weaknesses}}
            <div class="dshomebrew-dmg-entry" data-index="{{@index}}">
              <select data-field="weaknesses-type" data-index="{{@index}}">
                {{#each ../damageTypeOptionsAll}}
                <option value="{{key}}" {{#if (eq key ../type)}}selected{{/if}}>{{label}}</option>
                {{/each}}
              </select>
              <input type="number" data-field="weaknesses-value" data-index="{{@index}}" value="{{value}}" min="0" class="dshomebrew-dmg-value">
              <button type="button" class="dshomebrew-btn-icon" data-action="removeWeakness" data-index="{{@index}}" title="Remove">
                <i class="fa-solid fa-xmark"></i>
              </button>
            </div>
            {{/each}}
            <button type="button" class="dshomebrew-btn-small" data-action="addWeakness">
              <i class="fa-solid fa-plus"></i> {{localize "DSENCOUNTER.Homebrew.AddWeakness"}}
            </button>
          </div>
        </div>
      </section>

      {{!-- Characteristics --}}
      <section class="dshomebrew-section">
        <h3 class="dshomebrew-section-title">{{localize "DSENCOUNTER.Homebrew.Section.Characteristics"}}</h3>

        <div class="dshomebrew-char-grid">
          {{#each chars}}
          <div class="dshomebrew-char-field">
            <label>{{label}}</label>
            <input type="number" data-field="characteristics" data-index="{{@index}}" value="{{value}}">
          </div>
          {{/each}}
        </div>

        <div class="dshomebrew-suggested">
          <span class="dshomebrew-hint">
            {{localize "DSENCOUNTER.Homebrew.Hint.Suggested"}}
            {{#each suggestedChars}}{{#unless @first}}, {{/unless}}{{this}}{{/each}}
          </span>
          <button type="button" class="dshomebrew-btn-small" data-action="applySuggested">
            <i class="fa-solid fa-wand-magic-sparkles"></i> {{localize "DSENCOUNTER.Homebrew.ApplySuggested"}}
          </button>
        </div>

      </section>

      {{!-- Abilities --}}
      <section class="dshomebrew-section">
        <h3 class="dshomebrew-section-title">{{localize "DSENCOUNTER.Homebrew.Section.Abilities"}}</h3>

        <div class="dshomebrew-ability-actions">
          <button type="button" class="dshomebrew-btn-ability" data-action="addAbility">
            <i class="fa-solid fa-bolt"></i> {{localize "DSENCOUNTER.Homebrew.AddAbility"}}
          </button>
          <button type="button" class="dshomebrew-btn-ability" data-action="addFeature">
            <i class="fa-solid fa-scroll"></i> {{localize "DSENCOUNTER.Homebrew.AddTrait"}}
          </button>
          <button type="button" class="dshomebrew-btn-ability" data-action="addMalice">
            <i class="fa-solid fa-skull"></i> {{localize "DSENCOUNTER.Homebrew.AddMalice"}}
          </button>
        </div>

        {{!-- Ability editors (one per added ability) --}}
        {{#each abilityEditors}}
        {{> "modules/draw-steel-encounter-builder/templates/homebrew/partials/ability-editor.hbs" }}
        {{/each}}

        {{!-- Feature editors --}}
        {{#each featureEditors}}
        <div class="dshomebrew-feature-editor" data-feature-id="{{id}}">
          <div class="dshomebrew-ability-editor-header">
            <h4><i class="fa-solid fa-scroll"></i> {{localize "DSENCOUNTER.Homebrew.AddTrait"}}</h4>
            <button type="button" class="dshomebrew-btn-icon" data-action="removeFeature" data-feature-id="{{id}}" title="Remove">
              <i class="fa-solid fa-trash"></i>
            </button>
          </div>
          <div class="dshomebrew-field">
            <label>{{localize "DSENCOUNTER.Homebrew.Field.Name"}}</label>
            <input type="text" data-feature-field="name" value="{{name}}" placeholder="{{localize "DSENCOUNTER.Homebrew.Placeholder.FeatureName"}}">
          </div>
          <div class="dshomebrew-field">
            <label>{{localize "DSENCOUNTER.Homebrew.Field.Description"}}</label>
            <textarea data-feature-field="description" rows="3" placeholder="{{localize "DSENCOUNTER.Homebrew.Placeholder.FeatureDescription"}}">{{description}}</textarea>
          </div>
        </div>
        {{/each}}
      </section>

    </div>{{!-- .dshomebrew-input-panel --}}

    {{!-- ══════════ RIGHT PANEL: Stat Block Preview ══════════ --}}
    <div class="dshomebrew-preview-panel">
      <div class="dshomebrew-statblock">

        {{!-- Header --}}
        <div class="dshomebrew-sb-header">
          <div class="dshomebrew-sb-name">{{#if data.name}}{{data.name}}{{else}}<span class="dshomebrew-sb-placeholder">{{localize "DSENCOUNTER.Homebrew.Placeholder.Name"}}</span>{{/if}}</div>
          <div class="dshomebrew-sb-subtitle">
            {{localize "DSENCOUNTER.Homebrew.Preview.Level"}} {{data.level}} {{roleLabel}} ({{orgLabel}})
          </div>
        </div>

        {{!-- Keywords / Type line --}}
        {{#if keywordLabels.length}}
        <div class="dshomebrew-sb-line dshomebrew-sb-keywords">
          <span class="dshomebrew-sb-label">{{localize "DSENCOUNTER.Homebrew.Preview.Keywords"}}:</span> {{keywordLabels}}
        </div>
        {{/if}}

        <div class="dshomebrew-sb-divider"></div>

        {{!-- EV --}}
        <div class="dshomebrew-sb-line">
          <span class="dshomebrew-sb-label">EV:</span>
          {{#if isMinion}}{{stats.ev}} ({{localize "DSENCOUNTER.Homebrew.Preview.EVFor4"}}){{else}}{{stats.ev}}{{/if}}
        </div>

        {{!-- Stamina --}}
        <div class="dshomebrew-sb-line">
          <span class="dshomebrew-sb-label">{{localize "DSENCOUNTER.Homebrew.Stat.Stamina"}}:</span> {{stats.stamina}}
        </div>

        {{!-- Speed / Movement --}}
        <div class="dshomebrew-sb-line">
          <span class="dshomebrew-sb-label">{{localize "DSENCOUNTER.Homebrew.Field.Speed"}}:</span> {{data.speed}}{{#if movementLabel}} ({{movementLabel}}){{/if}}
        </div>

        {{!-- Size --}}
        <div class="dshomebrew-sb-line">
          <span class="dshomebrew-sb-label">{{localize "DSENCOUNTER.Homebrew.Field.Size"}}:</span> {{sizeDisplay}}
        </div>

        {{!-- Stability --}}
        {{#if data.stability}}
        <div class="dshomebrew-sb-line">
          <span class="dshomebrew-sb-label">{{localize "DSENCOUNTER.Homebrew.Field.Stability"}}:</span> {{data.stability}}
        </div>
        {{/if}}

        {{!-- Free Strike --}}
        <div class="dshomebrew-sb-line">
          <span class="dshomebrew-sb-label">{{localize "DSENCOUNTER.Homebrew.Stat.FreeStrike"}}:</span> {{stats.freeStrike}}
        </div>

        {{!-- Immunities --}}
        {{#if immunityDisplay}}
        <div class="dshomebrew-sb-line">
          <span class="dshomebrew-sb-label">{{localize "DSENCOUNTER.Homebrew.Field.Immunities"}}:</span> {{immunityDisplay}}
        </div>
        {{/if}}

        {{!-- Weaknesses --}}
        {{#if weaknessDisplay}}
        <div class="dshomebrew-sb-line">
          <span class="dshomebrew-sb-label">{{localize "DSENCOUNTER.Homebrew.Field.Weaknesses"}}:</span> {{weaknessDisplay}}
        </div>
        {{/if}}

        <div class="dshomebrew-sb-divider"></div>

        {{!-- Characteristics --}}
        <div class="dshomebrew-sb-chars">
          {{#each chars}}
          <div class="dshomebrew-sb-char">
            <span class="dshomebrew-sb-char-label">{{abbrev}}</span>
            <span class="dshomebrew-sb-char-value">{{#if (gt value 0)}}+{{/if}}{{value}}</span>
          </div>
          {{/each}}
        </div>

        <div class="dshomebrew-sb-divider"></div>

        {{!-- Features (displayed above abilities) --}}
        {{#if hasFeatures}}
        <div class="dshomebrew-sb-feature-group">
          <div class="dshomebrew-sb-group-label">{{localize "DSENCOUNTER.Homebrew.Preview.Features"}}</div>
          {{#each featurePreviews}}
          <div class="dshomebrew-sb-feature">
            <span class="dshomebrew-sb-feature-name">
              <i class="fa-solid fa-scroll"></i>
              {{#if name}}{{name}}{{else}}<em>{{localize "DSENCOUNTER.Homebrew.Placeholder.FeatureName"}}</em>{{/if}}
            </span>
            {{#if description}}
            <div class="dshomebrew-sb-feature-desc">{{description}}</div>
            {{/if}}
          </div>
          {{/each}}
        </div>
        {{/if}}

        {{!-- Abilities grouped by type --}}
        {{#each abilityGroups}}
        <div class="dshomebrew-sb-ability-group">
          <div class="dshomebrew-sb-group-label">{{typeLabel}}</div>
          {{#each abilities}}
          <div class="dshomebrew-sb-ability">
            <div class="dshomebrew-sb-ability-header">
              <span class="dshomebrew-sb-ability-name">
                {{#if (eq abilityCategory "signature")}}<i class="fa-solid fa-star"></i> {{/if}}
                {{#if isMalice}}<i class="fa-solid fa-skull"></i> {{/if}}
                {{#if name}}{{name}}{{else}}{{localize "DSENCOUNTER.Homebrew.Placeholder.AbilityName"}}{{/if}}
              </span>
              {{#if resourceCost}}<span class="dshomebrew-sb-ability-cost">{{resourceCost}} Malice</span>{{/if}}
            </div>
            {{#if categoryLabel}}
            <div class="dshomebrew-sb-ability-meta">
              Category: {{categoryLabel}}
            </div>
            {{/if}}
            {{#if isTriggered}}
            <div class="dshomebrew-sb-ability-meta">
              Trigger: {{#if trigger}}{{trigger}}{{else}}<em>—</em>{{/if}}
            </div>
            {{/if}}
            <div class="dshomebrew-sb-ability-meta">
              {{#if keywordLabels}}Keywords: {{keywordLabels}}<br>{{/if}}
              Distance: {{distanceLabel}} ◆ Target: {{targetLabel}}
            </div>
            {{#if hasPowerRoll}}
            <div class="dshomebrew-sb-ability-roll">
              Power Roll + {{charLabel}}
            </div>
            {{/if}}
            {{#if hasEffects}}
            <div class="dshomebrew-sb-tiers">
              <div class="dshomebrew-sb-tier">
                <span class="dshomebrew-sb-tier-label">≤11:</span>
                <span>{{tierPreview.[1]}}</span>
              </div>
              <div class="dshomebrew-sb-tier">
                <span class="dshomebrew-sb-tier-label">12–16:</span>
                <span>{{tierPreview.[2]}}</span>
              </div>
              <div class="dshomebrew-sb-tier">
                <span class="dshomebrew-sb-tier-label">17+:</span>
                <span>{{tierPreview.[3]}}</span>
              </div>
            </div>
            {{/if}}
            {{#if effectAfter}}
            <div class="dshomebrew-sb-effect-after">
              <span class="dshomebrew-sb-label">{{localize "DSENCOUNTER.Homebrew.Preview.EffectAfter"}}:</span> {{effectAfter}}
            </div>
            {{/if}}
          </div>
          {{/each}}
        </div>
        {{/each}}

      </div>{{!-- .dshomebrew-statblock --}}
    </div>{{!-- .dshomebrew-preview-panel --}}

  </div>{{!-- .dshomebrew-wizard-body --}}

  {{!-- Footer --}}
  <footer class="dshomebrew-wizard-footer">
    <div class="dshomebrew-spacer"></div>
    <button type="button" class="dshomebrew-btn-create" data-action="createMonster">
      <i class="fa-solid fa-plus"></i> {{localize "DSENCOUNTER.Homebrew.CreateMonster"}}
    </button>
  </footer>

</div>
